<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:macro name="probot_gripper" params="parent">

    <joint name="gripper_fix" type="fixed">
      <origin xyz="0 -0.013 0" rpy="1.5708 0 0" />
      <parent link="${parent}" />
      <child link="container_link" />
    </joint>

    <link name="container_link">
      <inertial>
        <origin xyz="0.000447954091404787 -0.00107076507649284 0.0812946823616097" rpy="0 0 0" />
        <mass value="0.681340710246045" />
        <inertia ixx="0.00162547625339366" ixy="-1.15400897004502E-05" ixz="-0.000149060142106832" iyy="0.00119115753501657" iyz="-5.15077727016555E-06" izz="0.00199811682178253" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry><mesh filename="package://probot_description/meshes/container_link.STL" /></geometry>
        <material name="grey"><color rgba="0.698 0.698 0.698 1" /></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry><mesh filename="package://probot_description/meshes/container_link.STL" /></geometry>
      </collision>
    </link>

    <link name="Active_Gear_Link">
      <inertial>
        <origin xyz="0.00040341000589738 -0.0028994921557112 0.00197147955183292" rpy="0 0 0" />
        <mass value="0.00284856456686766" />
        <inertia ixx="2.35656397042425E-07" ixy="8.29499629182763E-10" ixz="-2.06306214180894E-08" iyy="3.62849121452055E-07" iyz="4.23956057615974E-09" izz="1.36875683236315E-07" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry><mesh filename="package://probot_description/meshes/Active_Gear_Link.STL" /></geometry>
        <material name="grey"/>
      </visual>
    </link>

    <joint name="Active_Gear_Joint" type="revolute">
      <origin xyz="0.0437309784718086 -0.0355318582436578 0.122199999999998" rpy="-1.5707963267949 0 -1.57776049235038" />
      <parent link="container_link" />
      <child link="Active_Gear_Link" />
      <axis xyz="0 -1 0" />
      <limit lower="-0.56" upper="0" effort="10" velocity="6.28" /> 
    </joint>

    <link name="Active_Blade_Link">
      <inertial>
        <origin xyz="-0.00154255115951425 -0.0255142318483652 -0.0018089155442183" rpy="0 0 0" />
        <mass value="0.00546626517024223" />
