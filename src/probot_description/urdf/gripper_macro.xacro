      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry><mesh filename="package://probot_description/meshes/Active_Blade_Link.STL" /></geometry>
        <material name="robot_color"/>
      </visual>
    </link>

    <joint name="Active_Blade_Joint" type="fixed">
      <origin xyz="-0.00858698517037926 -0.0104000000000003 -1.5518750895907E-05" rpy="1.57079632679489 0.466732735623451 0" />
      <parent link="Active_Gear_Link" />
      <child link="Active_Blade_Link" />
    </joint>

    <link name="Passive_Gear_Link">
      <inertial>
        <origin xyz="-0.000253400477745899 -0.00227133697178923 0.00309286454693159" rpy="0 0 0" />
        <mass value="0.00320790725939746" />
        <inertia ixx="2.82029475359522E-07" ixy="-1.16262919185086E-09" ixz="1.21504474417119E-08" iyy="4.04760375455283E-07" iyz="1.34798056582785E-08" izz="1.37169661043404E-07" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry><mesh filename="package://probot_description/meshes/Passive_Gear_Link.STL" /></geometry>
