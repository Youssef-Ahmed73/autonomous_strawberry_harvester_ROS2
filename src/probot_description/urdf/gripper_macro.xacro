    <joint name="Passive_Blade_Joint" type="fixed">
      <origin xyz="0.012465980541461 -0.00399999999999064 0.00164188866873218" rpy="-1.57079632679489 0.126637396622301 3.14159265358979" />
      <parent link="Passive_Gear_Link" />
      <child link="Passive_Blade_Link" />
    </joint>

    </xacro:macro>
</robot>