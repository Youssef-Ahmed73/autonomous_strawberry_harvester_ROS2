      <child link="Passive_Gear_Link" />
      <axis xyz="0 -1 0" />
      <limit lower="0" upper="6.28" effort="10" velocity="6.28" />
      <mimic joint="Active_Gear_Joint" multiplier="-1.0" offset="0" />
    </joint>

    <link name="Passive_Blade_Link">
      <inertial>
        <origin xyz="-0.0108189596133123 0.0232787197714948 0.00489030573864965" rpy="0 0 0" />
        <mass value="0.00546978333218875" />
        <inertia ixx="1.39437733552038E-06" ixy="5.61593218262089E-07" ixz="7.42692648485945E-10" iyy="2.59809958482698E-07" iyz="-1.33879102104523E-09" izz="1.65014466299776E-06" />
